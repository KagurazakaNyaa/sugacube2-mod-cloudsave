{
    "name": "CloudSaveS3",
    "version": "0.0.1",
    "styleFileList": [],
    "scriptFileList": [
        "js/cloudsave_s3_adapter_script.js"
    ],
    "tweeFileList": [
        "twee/options.twee"
    ],
    "imgFileList": [],
    "additionFile": [
        "readme.txt"
    ],
    "addonPlugin": [
        {
            "modName": "TweeReplacer",
            "addonName": "TweeReplacerAddon",
            "modVersion": "1.0.0",
            "params": [
                {
                    "passage": "Saves Export/Import Overlay",
                    "findRegex": "(<input\\s+type=\"button\"\\s+class=\"saveMenuButton\"\\s+value=\"[^\"]*\"\\s+onclick=\"loadSaveData\\(\\)\"\\s*\\/>)(\\s*<input\\s+id=\"CopyTextArea\")",
                    "regexFlag": "g",
                    "replace": "$1\n<<cloudsaveS3EntryButton>>$2"
                }
            ]
        }
    ],
    "dependenceInfo": [
        {
            "modName": "TweeReplacer",
            "version": "^1.0.0"
        },
        {
            "modName": "ReplacePatcher",
            "version": "^1.0.0"
        }
    ]
}
